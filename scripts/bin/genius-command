#!/usr/bin/env bash
set -euo pipefail

SELF_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
PROJECT_ROOT="$(cd "$SELF_DIR/../.." && pwd)"
cd "$PROJECT_ROOT"

source "$PROJECT_ROOT/scripts/lib/contract.sh"

CMD="$(basename "$0")"
ARGS=("$@")

GREEN='\033[0;32m'
YELLOW='\033[1;33m'
RED='\033[0;31m'
BLUE='\033[0;34m'
NC='\033[0m'

info(){ echo -e "${BLUE}ℹ${NC}  $*"; }
ok(){ echo -e "${GREEN}✓${NC}  $*"; }
warn(){ echo -e "${YELLOW}⚠${NC}  $*"; }
die(){ echo -e "${RED}✗${NC}  $*" >&2; exit 1; }

need_file(){ [ -f "$1" ] || die "Missing file: $1"; }

ensure_contract() {
  gt_ensure_memory_files
  [ -f ".genius/config.json" ] || gt_write_config_json ".genius/config.json" "$(gt_default_install_mode)" "claude"
  [ -f ".genius/mode.json" ] || gt_write_mode_json ".genius/mode.json" "$(gt_default_experience_mode)" "command"
  [ -f ".genius/state.json" ] || gt_write_state_json ".genius/state.json" "$(gt_default_experience_mode)" "$(gt_default_install_mode)" "claude" "native" "native-v22" "not_run" "$(gt_default_phase)" "null" "null" "null" "false"
  [ -f ".genius/outputs/state.json" ] || gt_write_outputs_state_json ".genius/outputs/state.json" "$(jq -r '.phase // "NOT_STARTED"' .genius/state.json 2>/dev/null || echo "NOT_STARTED")"
  [ -f ".genius/DASHBOARD.html" ] || gt_write_dashboard_html ".genius/DASHBOARD.html" "$(basename "$PROJECT_ROOT")"
  [ -f ".genius/session-log.jsonl" ] || touch ".genius/session-log.jsonl"
  gt_ensure_wiki_files "$(basename "$PROJECT_ROOT")"
}

json_get() {
  local file="$1"
  local expr="$2"
  local fallback="${3:-}"
  local value
  value="$(jq -r "$expr" "$file" 2>/dev/null || true)"
  if [ -z "$value" ] || [ "$value" = "null" ]; then
    printf '%s' "$fallback"
  else
    printf '%s' "$value"
  fi
}

write_status_update() {
  local tmp_state tmp_outputs
  tmp_state="$(mktemp)"
  jq \
    --arg updatedAt "$(gt_now)" \
    --arg bootstrap "completed" \
    '.bootstrapStatus = $bootstrap |
     .compatibility.cortexReady = (.migrationStatus == "cortex-ready") |
     .updated_at = $updatedAt' \
    .genius/state.json > "$tmp_state"
  mv "$tmp_state" .genius/state.json

  tmp_outputs="$(mktemp)"
  jq \
    --arg phase "$(jq -r '.phase // "NOT_STARTED"' .genius/state.json 2>/dev/null || echo "NOT_STARTED")" \
    --arg updatedAt "$(gt_now)" \
    '.currentPhase = $phase |
     .dashboard.path = ".genius/DASHBOARD.html" |
     .dashboard.generated = true |
     .dashboard.generatedAt = $updatedAt |
     .updatedAt = $updatedAt' \
    .genius/outputs/state.json > "$tmp_outputs"
  mv "$tmp_outputs" .genius/outputs/state.json
  gt_ensure_wiki_files "$(basename "$PROJECT_ROOT")"
}

show_command_help() {
  cat <<EOF
Available local Genius commands:
  genius-start genius-dashboard genius-upgrade dual-status dual-challenge
  status continue reset save-tokens update-check genius-mode
  genius-switch-engine genius-import playground-update
EOF
}

dispatch_command() {
  local fn="$1"
  if [ "${#ARGS[@]}" -gt 0 ]; then
    "$fn" "${ARGS[@]}"
  else
    "$fn"
  fi
}

render_status() {
  ensure_contract
  echo "📊 Genius Team $(gt_version) — Project Status"
  echo ""
  echo "Install mode:   $(json_get .genius/config.json '.installMode // .mode' 'cli')"
  echo "Engine:         $(json_get .genius/config.json '.engine' 'claude')"
  echo "Experience:     $(json_get .genius/mode.json '.mode' 'builder')"
  echo ""
  echo "Phase:          $(json_get .genius/state.json '.phase' 'NOT_STARTED')"
  echo "Current skill:  $(json_get .genius/state.json '.currentSkill' 'none')"
  echo "Workflow:       $(json_get .genius/state.json '.currentWorkflow' 'none')"
  echo "Origin:         $(json_get .genius/state.json '.origin' 'native')"
  echo ""
  echo "Contract:"
  echo "  Version:      $(json_get .genius/state.json '.version' 'unknown')"
  echo "  Contract:     $(json_get .genius/state.json '.contractVersion' 'unknown')"
  echo "  Migration:    $(json_get .genius/state.json '.migrationStatus' 'unknown')"
  echo "  Bootstrap:    $(json_get .genius/state.json '.bootstrapStatus' 'unknown')"
  echo "  Cortex-ready: $(json_get .genius/state.json '.compatibility.cortexReady' 'false')"
  echo ""
  echo "Tasks: $(json_get .genius/state.json '.tasks.completed' '0')/$(json_get .genius/state.json '.tasks.total' '0') complete"
  echo "Dashboard: open .genius/DASHBOARD.html"
}

command_genius_start() {
  ensure_contract
  bash scripts/migrate-state.sh >/dev/null
  gt_append_session_event ".genius/session-log.jsonl" "bootstrap" "ok" "genius-start executed"
  write_status_update

  echo "╔════════════════════════════════════════════════════╗"
  echo "║  🧠 Genius Team $(gt_version) — Environment Ready        ║"
  echo "╚════════════════════════════════════════════════════╝"
  echo ""
  render_status
  echo ""
  echo "Ready. Useful next actions:"
  echo "  status"
  echo "  continue"
  echo "  genius-dashboard"
}

command_genius_dashboard() {
  ensure_contract
  local outputs first tabs file path name source phase tmp
  if jq -e '.outputs | length > 0' .genius/outputs/state.json >/dev/null 2>&1; then
    :
  else
    tmp="$(mktemp)"
    jq --arg updatedAt "$(gt_now)" '
      .outputs = (
        [inputs] | .[0]
      )' .genius/outputs/state.json >/dev/null 2>&1 || true
  fi

  outputs="$(find .genius/outputs -maxdepth 1 -name '*.html' -print | sort || true)"
  if [ -z "$outputs" ]; then
    gt_write_dashboard_html ".genius/DASHBOARD.html" "$(basename "$PROJECT_ROOT")"
    ok "No runtime outputs found yet. Placeholder dashboard refreshed."
    exit 0
  fi

  first="$(printf '%s\n' "$outputs" | head -1 | sed 's#^./##')"
  tabs=""
  while IFS= read -r file; do
    [ -z "$file" ] && continue
    path="${file#./}"
    name="$(basename "${file%.html}")"
    tabs="${tabs}<button class=\"tab\" onclick=\"show('${path}', this)\">${name}</button>"
  done <<< "$outputs"

  cat > .genius/DASHBOARD.html <<EOF
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>$(basename "$PROJECT_ROOT") — Genius Team Dashboard</title>
  <style>
    *{box-sizing:border-box}body{margin:0;font-family:-apple-system,BlinkMacSystemFont,"Segoe UI",sans-serif;background:#0a0a0f;color:#e2e8f0;display:flex;flex-direction:column;height:100vh}
    header{padding:14px 18px;background:#13131a;border-bottom:1px solid #232336}
    h1{margin:0;font-size:1rem}.tabs{display:flex;gap:8px;padding:10px 12px;background:#0d0d14;border-bottom:1px solid #232336;overflow:auto}
    .tab{padding:7px 12px;border-radius:8px;border:1px solid #232336;background:#141420;color:#cbd5e1;cursor:pointer}
    iframe{flex:1;border:none;width:100%}
  </style>
</head>
<body>
  <header><h1>🧠 $(basename "$PROJECT_ROOT") — Genius Team Dashboard</h1></header>
  <div class="tabs">${tabs}</div>
  <iframe id="frame" src="${first}"></iframe>
  <script>
    const tabs = document.querySelectorAll('.tab');
    if (tabs[0]) tabs[0].style.borderColor = '#7c3aed';
    function show(src, el) {
      document.getElementById('frame').src = src;
      tabs.forEach(t => t.style.borderColor = '#232336');
      el.style.borderColor = '#7c3aed';
    }
  </script>
</body>
</html>
EOF

  tmp="$(mktemp)"
  jq --arg updatedAt "$(gt_now)" '
    .dashboard.generated = true |
    .dashboard.generatedAt = $updatedAt |
    .dashboard.path = ".genius/DASHBOARD.html" |
    .updatedAt = $updatedAt' .genius/outputs/state.json > "$tmp"
  mv "$tmp" .genius/outputs/state.json

  ok "Dashboard generated: .genius/DASHBOARD.html"
}

command_dual_status() {
  ensure_contract
  if [ ! -f .genius/dual-state.json ]; then
    cat > .genius/dual-state.json <<EOF
{"active":false,"mode":null,"cycle":0,"max_rounds":3,"builder_model":"opus","challenger_model":"codex","challenger_profile":"balanced","current_task":null,"last_verdict":null,"history":[],"updated_at":"$(gt_now)"}
EOF
  fi
  jq . .genius/dual-state.json
}

command_dual_challenge() {
  ensure_contract
  local profile
  profile="${1:-balanced}"
  cat > .genius/dual-review-request.md <<EOF
# Dual Review Request

- Requested at: $(gt_now)
- Challenger profile: ${profile}
- Project root: ${PROJECT_ROOT}
EOF
  gt_append_session_event ".genius/session-log.jsonl" "dual-challenge" "ok" "dual challenge requested (${profile})"
  ok "Wrote .genius/dual-review-request.md"
}

command_status() {
  render_status
}

command_continue() {
  ensure_contract
  echo "▶ Continue"
  echo "Phase:   $(json_get .genius/state.json '.phase' 'NOT_STARTED')"
  echo "Current: $(json_get .genius/state.json '.currentSkill' 'none')"
  echo "Migration: $(json_get .genius/state.json '.migrationStatus' 'unknown')"
  echo "Bootstrap: $(json_get .genius/state.json '.bootstrapStatus' 'unknown')"
}

command_reset() {
  local confirm="${1:-}"
  [ "$confirm" = "--yes" ] || die "Reset is destructive. Re-run with: reset --yes"
  ensure_contract
  local backup=".genius/backups/$(date +%Y%m%d_%H%M%S)"
  mkdir -p "$backup"
  cp .genius/state.json "$backup/" 2>/dev/null || true
  cp .genius/outputs/state.json "$backup/" 2>/dev/null || true
  cp .genius/session-log.jsonl "$backup/" 2>/dev/null || true
  gt_write_state_json ".genius/state.json" "$(json_get .genius/mode.json '.mode' 'builder')" "$(json_get .genius/config.json '.installMode // .mode' 'cli')" "$(json_get .genius/config.json '.engine' 'claude')" "native" "native-v22" "not_run" "NOT_STARTED" "null" "null" "null" "false"
  gt_write_outputs_state_json ".genius/outputs/state.json" "NOT_STARTED"
  : > .genius/session-log.jsonl
  gt_write_dashboard_html ".genius/DASHBOARD.html" "$(basename "$PROJECT_ROOT")"
  gt_append_session_event ".genius/session-log.jsonl" "reset" "ok" "project reset"
  gt_ensure_wiki_files "$(basename "$PROJECT_ROOT")"
  ok "Project reset complete. Backup: $backup"
}

command_save_tokens() {
  ensure_contract
  local enabled
  enabled="$(json_get .genius/config.json '.models.saveTokenMode' || echo false)"
  if [ "$enabled" = "true" ]; then
    enabled=false
  else
    enabled=true
  fi
  jq --argjson enabled "$enabled" --arg updatedAt "$(gt_now)" \
    '.models.saveTokenMode = $enabled | .updated_at = $updatedAt' \
    .genius/config.json > .genius/config.json.tmp
  mv .genius/config.json.tmp .genius/config.json
  ok "Save-token mode: $enabled"
}

command_update_check() {
  local stored_claude current_claude stored_codex current_codex
  stored_claude=$(cat .genius/claude-code-version.txt 2>/dev/null || echo unknown)
  current_claude=$(claude --version 2>/dev/null | head -1 || echo unknown)
  stored_codex=$(cat .genius/codex-cli-version.txt 2>/dev/null || echo unknown)
  current_codex=$(codex --version 2>/dev/null | head -1 || echo unknown)
  echo "Claude Code:"
  echo "  Stored:  $stored_claude"
  echo "  Current: $current_claude"
  echo "Codex CLI:"
  echo "  Stored:  $stored_codex"
  echo "  Current: $current_codex"
}

command_genius_mode() {
  ensure_contract
  local chosen="${1:-}"
  if [ -z "$chosen" ]; then
    echo "Current mode: $(json_get .genius/mode.json '.mode' || echo builder)"
    echo "Available: beginner | builder | pro | agency"
    exit 0
  fi
  [[ "$chosen" =~ ^(beginner|builder|pro|agency)$ ]] || die "Invalid mode: $chosen"
  gt_write_mode_json ".genius/mode.json" "$chosen" "user"
  jq --arg mode "$chosen" --arg updatedAt "$(gt_now)" '.mode = $mode | .updated_at = $updatedAt' .genius/state.json > .genius/state.json.tmp
  mv .genius/state.json.tmp .genius/state.json
  ok "Mode switched to: $chosen"
}

command_genius_switch_engine() {
  bash scripts/switch-engine.sh "$@"
}

command_genius_upgrade() {
  bash scripts/upgrade.sh "$@"
}

command_genius_import() {
  ensure_contract
  bash scripts/migrate-state.sh --imported "$@"
  bash scripts/migrate-cortex-ready.sh
  ok "Project imported into Genius Team and migrated for Cortex."
}

command_playground_update() {
  ensure_contract
  gt_append_session_event ".genius/session-log.jsonl" "outputs" "ok" "playground update requested"
  command_genius_dashboard
}

case "$CMD" in
  genius-start) dispatch_command command_genius_start ;;
  genius-dashboard) dispatch_command command_genius_dashboard ;;
  genius-upgrade) dispatch_command command_genius_upgrade ;;
  dual-status) dispatch_command command_dual_status ;;
  dual-challenge) dispatch_command command_dual_challenge ;;
  status) dispatch_command command_status ;;
  continue) dispatch_command command_continue ;;
  reset) dispatch_command command_reset ;;
  save-tokens) dispatch_command command_save_tokens ;;
  update-check) dispatch_command command_update_check ;;
  genius-mode) dispatch_command command_genius_mode ;;
  genius-switch-engine) dispatch_command command_genius_switch_engine ;;
  genius-import) dispatch_command command_genius_import ;;
  playground-update) dispatch_command command_playground_update ;;
  *) show_command_help; exit 1 ;;
esac
